---
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import SEOHead from '../components/SEO/SEOHead.astro';
import OrganizationSchema from '../components/SEO/OrganizationSchema.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  ogType?: string;
  canonicalURL?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  keywords,
  ogImage,
  ogType,
  canonicalURL,
  noindex
} = Astro.props;

const GTM_ID = String(import.meta.env.PUBLIC_GTM_ID || import.meta.env.GTM_ID || '').trim();
const hasGtm = GTM_ID.startsWith('GTM-');
const gtmScript = `(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','${GTM_ID}');`;

---

<!doctype html>
<html lang="ro">
  <head>
    <!-- Start CookieYes banner -->
    <script
      id="cookieyes"
      type="text/javascript"
      src="https://cdn-cookieyes.com/client_data/052e0cefac940a4135d1590a0efd33ea/script.js"
      is:inline
    ></script>
    <!-- End CookieYes banner -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO Meta Tags -->
    <SEOHead
      title={title}
      description={description}
      keywords={keywords}
      ogImage={ogImage}
      ogType={ogType}
      canonicalURL={canonicalURL}
      noindex={noindex}
    />

    <!-- Fonts - Preconnect for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=League+Spartan:wght@100..900&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=League+Spartan:wght@100..900&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <!-- Iconify -->
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js" is:inline></script>

    <!-- Google Tag Manager (CookieYes controlled: analytics consent) -->
    {hasGtm && (
      <script
        type="text/plain"
        data-cookieyes="cookieyes-analytics"
        is:inline
        set:html={gtmScript}
      />
    )}

    <!-- Structured Data - Organization Schema -->
    <OrganizationSchema />
  </head>
  <body
    class="bg-primary-bg text-primary-text font-sans antialiased selection:bg-accent selection:text-primary-bg overflow-x-hidden"
  >
    {hasGtm && (
      <noscript>
        <iframe
          src={`https://www.googletagmanager.com/ns.html?id=${GTM_ID}`}
          height="0"
          width="0"
          style="display:none;visibility:hidden"
        ></iframe>
      </noscript>
    )}
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:px-6 focus:py-3 focus:bg-accent focus:text-primary-bg focus:rounded-full focus:text-sm focus:font-bold focus:uppercase focus:tracking-[0.2em] focus:shadow-lg"
    >
      Sari la conținut
    </a>


    <div id="swup" class="transition-fade">
      <Navigation />
      <main class="w-full" id="main-content">
        <slot />
      </main>
      <Footer />
    </div>
    <WhatsAppButton />
  </body>
</html>

<style is:global>
  .transition-fade {
    transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  html.is-animating .transition-fade {
    opacity: 0;
  }

  /* Custom scrollbar for an editorial feel */
  ::-webkit-scrollbar {
    width: 8px;
  }
  ::-webkit-scrollbar-track {
    background: #efece5;
  }
  ::-webkit-scrollbar-thumb {
    background: #5d4037;
  }

  /* Reveal Animation Base Class */
  .reveal-up {
    opacity: 0;
    transform: translateY(40px);
    transition:
      opacity 1s cubic-bezier(0.16, 1, 0.3, 1),
      transform 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal-up.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Utility for 10px tracking labels */
  .util-label {
    font-size: 10px;
    font-weight: 900;
    letter-spacing: 0.4em;
    text-transform: uppercase;
  }

  /* Touch action optimization for mobile */
  html {
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
  }

  /* Reduced motion support */
  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
      scroll-behavior: auto !important;
    }
    .reveal-up {
      opacity: 1;
      transform: none;
    }
  }

  /* Hover-none: touch devices show grayscale images in color */
  @media (hover: none) and (pointer: coarse) {
    .grayscale {
      filter: grayscale(0) !important;
    }
  }
</style>

<script>
  import Swup from 'swup';
  import SwupHeadPlugin from '@swup/head-plugin';
  import SwupScriptsPlugin from '@swup/scripts-plugin';
  import LocomotiveScroll from 'locomotive-scroll';

  let revealObserver: IntersectionObserver | null = null;
  let locomotive: LocomotiveScroll | null = null;
  let swup: Swup | null = null;

  const reducedMotionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');

  const initRevealAnimations = () => {
    revealObserver?.disconnect();
    revealObserver = null;

    const revealElements = document.querySelectorAll<HTMLElement>('.reveal-up');
    if (!revealElements.length) {
      return;
    }

    if (reducedMotionQuery.matches) {
      revealElements.forEach((el) => el.classList.add('is-visible'));
      return;
    }

    revealObserver = new IntersectionObserver(
      (entries, observer) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) {
            return;
          }
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        });
      },
      {
        root: null,
        rootMargin: '0px',
        threshold: 0.15,
      },
    );

    revealElements.forEach((el) => revealObserver?.observe(el));
  };

  const destroyLocomotive = () => {
    if (!locomotive) {
      return;
    }
    locomotive.destroy();
    locomotive = null;
    document.documentElement.removeAttribute('data-scroll-orientation');
  };

  const initLocomotive = () => {
    if (reducedMotionQuery.matches) {
      destroyLocomotive();
      return;
    }

    destroyLocomotive();
    locomotive = new LocomotiveScroll({
      lenisOptions: {
        smoothWheel: true,
      },
    });
  };

  const renderTurnstileWidgets = () => {
    const turnstileApi = (
      window as {
        turnstile?: {
          render: (
            container: HTMLElement,
            options?: Record<string, unknown>,
          ) => unknown;
        };
      }
    ).turnstile;

    if (!turnstileApi) {
      return;
    }

    document.querySelectorAll<HTMLElement>('.cf-turnstile').forEach((widget) => {
      if (widget.dataset.turnstileRendered === 'true') {
        return;
      }

      if (widget.childElementCount > 0) {
        widget.dataset.turnstileRendered = 'true';
        return;
      }

      const sitekey = widget.dataset.sitekey;
      if (!sitekey) {
        return;
      }

      turnstileApi.render(widget, {
        sitekey,
        language: widget.dataset.language || 'ro',
        theme: widget.dataset.theme || 'light',
      });
      widget.dataset.turnstileRendered = 'true';
    });
  };

  const ensureTurnstileScript = () => {
    if (!document.querySelector('.cf-turnstile')) {
      return;
    }

    const turnstileApi = (
      window as {
        turnstile?: {
          render: (
            container: HTMLElement,
            options?: Record<string, unknown>,
          ) => unknown;
        };
      }
    ).turnstile;

    if (turnstileApi) {
      renderTurnstileWidgets();
      return;
    }

    if (document.querySelector('script[data-turnstile-api]')) {
      return;
    }

    const turnstileScript = document.createElement('script');
    turnstileScript.src = 'https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit';
    turnstileScript.async = true;
    turnstileScript.defer = true;
    turnstileScript.dataset.turnstileApi = 'true';
    turnstileScript.addEventListener('load', renderTurnstileWidgets, { once: true });
    document.head.appendChild(turnstileScript);
  };

  const initPageInteractions = () => {
    initRevealAnimations();
    ensureTurnstileScript();
    renderTurnstileWidgets();
    initLocomotive();
  };

  const initSwup = () => {
    if (swup) {
      return;
    }

    swup = new Swup({
      containers: ['#swup'],
      plugins: [
        new SwupHeadPlugin({
          // Keep third-party style/script tags injected at runtime (CookieYes, Turnstile, etc.).
          persistAssets: true,
        }),
        new SwupScriptsPlugin({
          head: false,
          body: true,
          optin: true,
        }),
      ],
    });

    swup.hooks.before('content:replace', () => {
      revealObserver?.disconnect();
      revealObserver = null;
      destroyLocomotive();
    });

    swup.hooks.on('page:view', () => {
      initPageInteractions();
    });
  };

  const bootstrapClient = () => {
    initPageInteractions();
    initSwup();
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bootstrapClient, { once: true });
  } else {
    bootstrapClient();
  }

  reducedMotionQuery.addEventListener('change', () => {
    initRevealAnimations();
    initLocomotive();
  });
</script>
