---
const currentPath = Astro.url.pathname;
---

<nav
  class="fixed top-0 w-full h-[80px] z-50 bg-[#F9F7F2]/85 backdrop-blur-[12px] border-b border-[#5D4037]/10 flex items-center justify-between px-6 md:px-12 transition-all duration-1000 ease-custom"
>
  <a
    href="/"
    class="font-black text-xl tracking-tight text-secondary-text"
  >
    WOOD & GRAIN
  </a>

  <ul class="hidden md:flex gap-12 items-center">
    <li>
      <a
        href="/"
        class={`text-[10px] uppercase font-bold tracking-[0.2em] hover:text-accent transition-colors duration-500 ${currentPath === '/' ? 'text-accent' : 'text-primary-text/70'}`}
      >
        Home
      </a>
    </li>
    <li>
      <a
        href="/about"
        class={`text-[10px] uppercase font-bold tracking-[0.2em] hover:text-accent transition-colors duration-500 ${currentPath === '/about' ? 'text-accent' : 'text-primary-text/70'}`}
      >
        About
      </a>
    </li>
    <li>
      <a
        href="/products"
        class={`text-[10px] uppercase font-bold tracking-[0.2em] hover:text-accent transition-colors duration-500 ${currentPath === '/products' ? 'text-accent' : 'text-primary-text/70'}`}
      >
        Products
      </a>
    </li>
    <li>
      <a
        href="/blog"
        class={`text-[10px] uppercase font-bold tracking-[0.2em] hover:text-accent transition-colors duration-500 ${currentPath === '/blog' ? 'text-accent' : 'text-primary-text/70'}`}
      >
        Blog
      </a>
    </li>
  </ul>

  <a
    href="/contact"
    class="bg-accent text-primary-bg px-[32px] py-[12px] rounded-full text-[10px] uppercase font-bold tracking-[0.2em] hover:bg-secondary-text transition-colors duration-500"
  >
    Contact
  </a>
</nav>
