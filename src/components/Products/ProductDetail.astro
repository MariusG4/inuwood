---
import CloudinaryImage from '../CloudinaryImage.astro';
import ProductInquiryForm from './ProductInquiryForm.astro';

interface Props {
  title: string;
  category: string;
  wood: string;
  year: string;
  image: string;
  alt: string;
  excerpt: string;
  gallery: { src: string; alt: string }[];
  price?: string;
  dimensions?: string;
  finish?: string;
  slug: string;
}

const {
  title,
  category,
  wood,
  year,
  image,
  alt,
  excerpt,
  gallery,
  price,
  dimensions,
  finish,
  slug,
} = Astro.props;

const specs = [
  { label: 'Categorie', value: category },
  { label: 'Lemn', value: wood },
  { label: 'An', value: year },
  ...(dimensions ? [{ label: 'Dimensiuni', value: dimensions }] : []),
  ...(finish ? [{ label: 'Finisaj', value: finish }] : []),
  ...(price ? [{ label: 'Preț', value: price }] : []),
];

const allImages =
  gallery.length > 0
    ? gallery
    : [{ src: image, alt }];
---

<article class="max-w-[1440px] mx-auto px-6 md:px-12 py-20" itemscope itemtype="https://schema.org/Product">
  <!-- Breadcrumb -->
  <nav aria-label="Breadcrumb" class="mb-8">
    <ol class="flex items-center gap-2 text-sm text-primary-text/60">
      <li><a href="/products" class="hover:text-accent transition-colors">Produse</a></li>
      <li aria-hidden="true">/</li>
      <li aria-current="page" class="text-secondary-text font-medium">{title}</li>
    </ol>
  </nav>

  <!-- Product Hero -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 mb-16">
    <!-- Main Image -->
    <div class="reveal-up">
      <div class="relative rounded-[24px] overflow-hidden aspect-[3/4]">
        <CloudinaryImage
          src={image}
          alt={alt}
          width={1200}
          height={1600}
          class="w-full h-full object-cover"
          loading="eager"
          itemprop="image"
        />
      </div>
    </div>

    <!-- Product Info -->
    <div class="reveal-up flex flex-col justify-center" style="transition-delay: 100ms">
      <span class="util-label text-accent mb-4 block" itemprop="category">{category}</span>
      <h1 class="text-4xl md:text-6xl font-black text-secondary-text tracking-tighter mb-6" itemprop="name">
        {title}
      </h1>
      <p class="text-xl text-primary-text/70 leading-relaxed mb-8" itemprop="description">
        {excerpt}
      </p>

      <!-- Specs Grid -->
      <div class="grid grid-cols-2 gap-4 mb-10">
        {specs.map((spec) => (
          <div class="bg-secondary-bg rounded-xl p-4 border border-secondary-text/10">
            <div class="text-xs uppercase tracking-[0.2em] text-primary-text/50 font-bold mb-1">
              {spec.label}
            </div>
            <div class="text-lg font-bold text-secondary-text">{spec.value}</div>
          </div>
        ))}
      </div>

      <a
        href="#inquiry-form"
        class="inline-flex items-center gap-4 bg-accent text-primary-bg px-8 py-4 rounded-full text-sm uppercase font-bold tracking-[0.2em] hover:bg-secondary-text transition-colors duration-500 w-fit"
      >
        Solicită Oferă
        <iconify-icon icon="lucide:arrow-right" class="text-lg" aria-hidden="true"></iconify-icon>
      </a>
    </div>
  </div>

  <!-- Gallery -->
  {
    allImages.length > 1 && (
      <section class="mb-20" aria-labelledby="gallery-heading">
        <h2 id="gallery-heading" class="text-2xl md:text-3xl font-black text-secondary-text tracking-tighter mb-8">
          Galerie
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {allImages.map((img, i) => (
            <div class="relative rounded-[16px] overflow-hidden aspect-[4/3] reveal-up" style={`transition-delay: ${i * 100}ms`}>
              <CloudinaryImage
                src={img.src}
                alt={img.alt}
                width={800}
                height={600}
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
          ))}
        </div>
      </section>
    )
  }

  <!-- Product Content -->
  <div class="max-w-3xl mx-auto mb-20">
    <div class="prose prose-lg max-w-none">
      <slot />
    </div>
  </div>

  <!-- Inquiry Form -->
  <div id="inquiry-form" class="max-w-3xl mx-auto">
    <ProductInquiryForm productName={title} productSlug={slug} />
  </div>

  <!-- Back Link -->
  <footer class="mt-16 pt-8 border-t border-secondary-text/10">
    <a
      href="/products"
      class="inline-flex items-center gap-2 text-accent font-bold text-sm uppercase tracking-[0.2em] hover:text-secondary-text transition-colors"
    >
      <iconify-icon icon="lucide:arrow-left" class="text-base"></iconify-icon>
      Înapoi la Produse
    </a>
  </footer>
</article>

<style>
  .prose {
    color: var(--tw-prose-body);
    max-width: 65ch;
  }

  .prose :global(h2) {
    font-size: 2rem;
    font-weight: 900;
    color: #5D4037;
    margin-top: 2.5rem;
    margin-bottom: 1.25rem;
    line-height: 1.2;
  }

  .prose :global(h3) {
    font-size: 1.5rem;
    font-weight: 900;
    color: #5D4037;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .prose :global(p) {
    margin-bottom: 1.5rem;
    line-height: 1.75;
    color: rgba(45, 44, 44, 0.8);
  }

  .prose :global(ul), .prose :global(ol) {
    margin: 1.5rem 0;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.75rem;
    line-height: 1.75;
  }

  .prose :global(strong) {
    font-weight: 700;
    color: #2D2C2C;
  }

  .prose :global(a) {
    color: #334B49;
    text-decoration: underline;
    transition: color 0.3s;
  }

  .prose :global(a:hover) {
    color: #5D4037;
  }
</style>
