---
interface Props {
  heading: string;
  description: string;
  ctaText: string;
  ctaLink: string;
  ctaAriaLabel?: string;
  backgroundColor?: string;
}

const {
  heading,
  description,
  ctaText,
  ctaLink,
  ctaAriaLabel,
  backgroundColor = 'bg-accent'
} = Astro.props;

const isAccentBg = backgroundColor === 'bg-accent';
const textColor = isAccentBg ? 'text-primary-bg' : 'text-secondary-text';
const buttonBg = isAccentBg ? 'bg-primary-bg text-accent hover:bg-secondary-bg' : 'bg-accent text-primary-bg hover:bg-secondary-text';
---

<section class={`py-32 md:py-48 px-6 md:px-12 ${backgroundColor}`}>
  <div class="max-w-[1440px] mx-auto text-center reveal-up">
    <h2 class={`text-4xl md:text-6xl font-black ${textColor} tracking-tighter mb-8`}>
      {heading}
    </h2>
    <p class={`text-xl ${isAccentBg ? 'text-primary-bg/80' : 'text-primary-text/70'} mb-12 max-w-2xl mx-auto`}>
      {description}
    </p>
    <a
      href={ctaLink}
      class={`inline-flex items-center gap-4 ${buttonBg} px-12 py-4 rounded-full text-sm uppercase font-bold tracking-[0.2em] transition-colors duration-500`}
      aria-label={ctaAriaLabel || ctaText}
    >
      {ctaText}
      <iconify-icon icon="lucide:arrow-right" class="text-lg" aria-hidden="true"></iconify-icon>
    </a>
  </div>
</section>
