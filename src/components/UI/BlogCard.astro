---
import CloudinaryImage from '../CloudinaryImage.astro';

interface Props {
  title: string;
  excerpt: string;
  date: string;
  category: string;
  image: string;
  readTime: string;
  slug: string;
  delay?: number;
}

const {
  title,
  excerpt,
  date,
  category,
  image,
  readTime,
  slug,
  delay = 0
} = Astro.props;
---

<article
  class="group reveal-up"
  style={delay ? `transition-delay: ${delay}ms` : undefined}
  itemscope
  itemtype="https://schema.org/BlogPosting"
>
  <a href={`/blog/${slug}`} class="block" aria-label={`Citește ${title}`}>
    <div class="relative rounded-[16px] overflow-hidden aspect-[4/3] mb-6">
      <CloudinaryImage
        src={image}
        alt={title}
        width={1200}
        height={900}
        class="w-full h-full object-cover group-hover:scale-[1.05] transition-transform duration-700 ease-custom"
        loading="lazy"
        itemprop="image"
      />
    </div>
    <div class="space-y-3">
      <div class="flex items-center gap-3 text-xs text-primary-text/60 font-medium">
        <span class="util-label text-accent" itemprop="articleSection">{category}</span>
        <span aria-hidden="true">&bull;</span>
        <time datetime={date} itemprop="datePublished">{date}</time>
        <span aria-hidden="true">&bull;</span>
        <span>{readTime}</span>
      </div>
      <h3 class="text-2xl md:text-3xl font-black text-secondary-text tracking-tighter group-hover:text-accent transition-colors duration-300" itemprop="headline">
        {title}
      </h3>
      <p class="text-base text-primary-text/70 leading-relaxed" itemprop="description">
        {excerpt}
      </p>
      <div class="inline-flex items-center gap-2 text-accent font-bold text-sm uppercase tracking-[0.2em] group-hover:gap-4 transition-all duration-300">
        Citește Mai Mult
        <iconify-icon icon="lucide:arrow-right" class="text-base" aria-hidden="true"></iconify-icon>
      </div>
    </div>
    <meta itemprop="author" content="InuWood" />
    <meta itemprop="publisher" content="InuWood" />
  </a>
</article>
