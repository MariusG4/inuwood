---
const turnstileSiteKey = String(
  import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || '1x00000000000000000000AA'
).trim();
---

<div class="w-full max-w-xs mx-auto pt-2 ">
  <div
    class="cf-turnstile"
    data-sitekey={turnstileSiteKey}
    data-language="ro"
    data-theme="light"
  ></div>
</div>
