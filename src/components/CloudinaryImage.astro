---
interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  widths?: number[];
  sizes?: string;
  class?: string;
  loading?: 'lazy' | 'eager';
  itemprop?: string;
  [key: string]: unknown;
}

const {
  src,
  alt,
  width,
  height,
  widths = [400, 800, 1200, 1600, 2000],
  sizes = '(max-width: 1440px) 100vw, 1440px',
  class: className,
  loading = 'lazy',
  itemprop,
  ...rest
} = Astro.props;

const isExternalUrl = src.startsWith('http://') || src.startsWith('https://');
const isLocalPath = src.startsWith('/') || src.startsWith('.');
const isCloudinary = !isExternalUrl && !isLocalPath;

const cloudName = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME;
const cloudinaryReady = isCloudinary && !!cloudName;

const generateCloudinaryUrl = (w?: number) => {
  const transformations = [
    'f_auto',
    'q_auto',
    w ? `w_${w}` : undefined,
    height && !w ? `h_${height}` : undefined,
  ].filter(Boolean).join(',');
  return `https://res.cloudinary.com/${cloudName}/image/upload/${transformations}/${src}`;
};

const cloudinarySrc = cloudinaryReady ? generateCloudinaryUrl(width) : undefined;
const cloudinarySrcSet = cloudinaryReady
  ? widths.filter(w => !width || w <= width * 2).map(w => `${generateCloudinaryUrl(w)} ${w}w`).join(', ')
  : undefined;

// Fallback to local images when Cloudinary is not configured
let resolvedSrc = src;
if (isCloudinary && !cloudName) {
  const extensionMap: Record<string, string> = {
    'about-us/despre-noi': '.jpg',
  };
  const ext = extensionMap[src] || '.webp';
  resolvedSrc = `/img/${src}${ext}`;
}

// Build extra HTML attributes map
const extraAttrs: Record<string, string | number | undefined> = {};
if (itemprop) extraAttrs['itemprop'] = itemprop;
for (const [key, value] of Object.entries(rest)) {
  if (typeof value === 'string' || typeof value === 'number' || typeof value === 'boolean') {
    extraAttrs[key] = value as string | number;
  }
}
---

{
  cloudinaryReady ? (
    <img
      src={cloudinarySrc}
      srcset={cloudinarySrcSet}
      sizes={sizes}
      alt={alt}
      width={width}
      height={height}
      class={className}
      loading={loading}
      {...extraAttrs}
    />
  ) : (
    <img
      src={resolvedSrc}
      alt={alt}
      width={width}
      height={height}
      class={className}
      loading={loading}
      {...extraAttrs}
    />
  )
}
