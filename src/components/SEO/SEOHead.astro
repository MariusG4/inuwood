---
interface Props {
  title: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  ogType?: string;
  canonicalURL?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  keywords,
  ogImage,
  ogType,
  canonicalURL,
  noindex
} = Astro.props;

const descriptionToUse = description ?? 'Mobilier din lemn masiv realizat manual cu tehnici tradiționale de tâmplărie. Calitate superioară și design personalizat în Bacău, Moldova, România.';
const keywordsToUse = keywords ?? 'mobilier lemn masiv, tâmplărie artizanală, mobila personalizată, lemn masiv Bacău, mobilier handmade România, restaurare mobilier Bacău, design mobilier lemn, atelier lemn Bacău';
const ogImageToUse = ogImage ?? '/og-image.svg';
const ogTypeToUse = ogType ?? 'website';
const canonicalURLToUse = canonicalURL ?? new URL(Astro.url.pathname, Astro.site).href;
const noindexToUse = noindex ?? false;

const siteURL = Astro.site || 'https://www.inuwood.ro';
const fullTitle = title.includes('InuWood') ? title : `${title} | InuWood`;

import { pwaInfo } from 'virtual:pwa-info';
---

<!-- Primary Meta Tags -->
<title>{fullTitle}</title>
<meta name="title" content={fullTitle} />
<meta name="description" content={descriptionToUse} />
<meta name="keywords" content={keywordsToUse} />
<meta name="author" content="InuWood" />
<meta name="generator" content={Astro.generator} />
{noindexToUse && <meta name="robots" content="noindex, nofollow" />}
{!noindexToUse && <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />}

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURLToUse} />

<!-- Favicon -->
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="shortcut icon" href="/favicon.ico" />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={ogTypeToUse} />
<meta property="og:url" content={canonicalURLToUse} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={descriptionToUse} />
<meta property="og:image" content={new URL(ogImageToUse, siteURL).href} />
<meta property="og:locale" content="ro_RO" />
<meta property="og:site_name" content="InuWood" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURLToUse} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={descriptionToUse} />
<meta name="twitter:image" content={new URL(ogImageToUse, siteURL).href} />

<!-- Additional Meta Tags -->
<meta name="theme-color" content="#5D4037" />
<meta name="color-scheme" content="light" />
<meta name="format-detection" content="telephone=no" />

<!-- PWA -->
{pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} />}
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="default" />
<meta name="apple-mobile-web-app-title" content="InuWood" />

<!-- Mobile optimization -->
<meta name="mobile-web-app-capable" content="yes" />
<meta name="application-name" content="InuWood" />
