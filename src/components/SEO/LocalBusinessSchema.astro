---
// Schema.org LocalBusiness - Used on homepage and contact page
interface Props {
  includedIn?: 'WebPage' | 'ContactPage';
}

const { includedIn = 'WebPage' } = Astro.props;
---

<script type="application/ld+json" is:inline set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": includedIn,
  "name": includedIn === 'WebPage' ? "InuWood - Mobilier din Lemn Masiv Realizat Manual" : "Contact InuWood",
  "description": includedIn === 'WebPage' 
    ? "Atelier de tâmplărie artizanală în Bacău. Creăm mobilier din lemn masiv cu tehnici tradiționale."
    : "Contactează atelierul InuWood pentru comenzi de mobilier personalizat sau restaurări",
  "url": includedIn === 'WebPage' ? "https://inuwood.ro" : "https://inuwood.ro/contact",
  "inLanguage": "ro-RO",
  ...(includedIn === 'WebPage' ? {
    "provider": {
      "@type": "LocalBusiness",
      "name": "InuWood",
      "image": "https://inuwood.ro/favicon.svg",
      "priceRange": "$$-$$$",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Str. Meșteșugului nr. 24",
        "addressLocality": "Bacău",
        "addressRegion": "BC",
        "postalCode": "600001",
        "addressCountry": "RO"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 46.5670,
        "longitude": 26.9146
      },
      "telephone": "+40234555198",
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
          "opens": "09:00",
          "closes": "17:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Saturday",
          "opens": "10:00",
          "closes": "15:00"
        }
      ]
    }
  } : {
    "mainEntity": {
      "@type": "LocalBusiness",
      "name": "InuWood",
      "telephone": "+40-234-555-198",
      "email": "contact@inuwood.ro",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Str. Meșteșugului nr. 24",
        "addressLocality": "Bacău",
        "addressRegion": "BC",
        "postalCode": "600001",
        "addressCountry": "RO"
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
          "opens": "09:00",
          "closes": "17:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Saturday",
          "opens": "10:00",
          "closes": "15:00"
        }
      ]
    }
  })
})} />
