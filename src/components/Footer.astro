---

<footer class="bg-secondary-bg py-24 px-6 md:px-12 border-t border-secondary-text/10">
  <div class="max-w-[1440px] mx-auto">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 lg:gap-16 mb-20">
      <!-- Sub-column 1 -->
      <div class="reveal-up col-span-2 md:col-span-1">
        <h4 class="util-label text-accent mb-8 pb-2 border-b border-secondary-text inline-block">
          Navigate
        </h4>
        <ul class="flex flex-col gap-4 text-sm font-medium text-primary-text/70">
          <li><a href="/" class="hover:text-accent transition-colors">Home</a></li>
          <li><a href="/about" class="hover:text-accent transition-colors">About</a></li>
          <li><a href="/products" class="hover:text-accent transition-colors">Products</a></li>
          <li><a href="/blog" class="hover:text-accent transition-colors">Blog</a></li>
          <li><a href="/contact" class="hover:text-accent transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Sub-column 2 -->
      <div class="reveal-up col-span-2 md:col-span-1" style="transition-delay: 150ms;">
        <h4 class="util-label text-accent mb-8 pb-2 border-b border-secondary-text inline-block">
          Follow
        </h4>
        <ul class="flex flex-col gap-4 text-sm font-medium text-primary-text/70">
          <li><a href="#" class="hover:text-accent transition-colors">Instagram</a></li>
          <li><a href="#" class="hover:text-accent transition-colors">Pinterest</a></li>
          <li><a href="#" class="hover:text-accent transition-colors">LinkedIn</a></li>
        </ul>
      </div>

      <!-- Sub-column 3 -->
      <div class="reveal-up col-span-2 md:col-span-1" style="transition-delay: 300ms;">
        <h4 class="util-label text-accent mb-8 pb-2 border-b border-secondary-text inline-block">
          Workshop
        </h4>
        <address class="not-italic flex flex-col gap-4 text-sm font-medium text-primary-text/70">
          <p>124 Timberline Way<br />Portland, OR 97204</p>
          <p class="mt-2">
            <a href="mailto:hello@woodandgrain.com" class="hover:text-accent transition-colors"
              >hello@woodandgrain.com</a
            ><br />
            +1 (503) 555-0198
          </p>
        </address>
      </div>
    </div>

    <div class="border-t border-secondary-text/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-xs text-primary-text/50 font-medium">
        &copy; {new Date().getFullYear()} Wood & Grain. All rights reserved.
      </p>
      <p class="text-xs text-primary-text/50 font-medium">
        Crafted with care in Portland, Oregon.
      </p>
    </div>
  </div>
</footer>
