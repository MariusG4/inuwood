---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/UI/Hero.astro';
import TurnstileWidget from '../components/UI/TurnstileWidget.astro';
import LocalBusinessSchema from '../components/SEO/LocalBusinessSchema.astro';

const pageTitle = "Contact - InuWood";
const pageDescription = "Contactează atelierul InuWood din Bacău pentru comenzi de mobilier personalizat, restaurări sau consultații. Program L-V 9-17, Sâmbătă 10-15.";
const pageKeywords = "contact InuWood, atelier lemn Bacău contact, comanda mobilier personalizat, consultanta mobilier lemn, restaurare mobilier Bacău, telefon atelier lemn";
---

<Layout
  title={pageTitle}
  description={pageDescription}
  keywords={pageKeywords}
  ogType="website"
>
  <!-- Hero Section -->
  <Hero
    label="Suntem Aici"
    heading="Contactează-ne"
    description="Ai un proiect în minte? Ne-ar plăcea să auzim de la tine. Completează formularul de mai jos sau contactează-ne direct."
    ariaLabelledBy="contact-heading"
    minHeight="min-h-[40vh]"
  />

  <!-- Contact Section -->
  <section class="py-32 md:py-48 px-6 md:px-12 bg-secondary-bg">
    <div class="max-w-[1440px] mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
        <!-- Contact Form -->
        <div class="reveal-up">
          <h2 class="text-3xl md:text-4xl font-black text-secondary-text tracking-tighter mb-8">
            Trimite-ne un Mesaj
          </h2>
          <div
            id="form-success"
            class="hidden mb-8 rounded-2xl border border-accent/30 bg-accent/10 px-6 py-5 text-primary-text"
            role="status"
            aria-live="polite"
            tabindex="-1"
          >
            <p class="font-bold text-secondary-text mb-2">Mulțumim! Mesajul a fost trimis.</p>
            <p class="text-primary-text/70">
              Am primit solicitarea ta și te vom contacta cât mai curând la datele trimise.
            </p>
          </div>

          <div
            id="form-error"
            class="hidden mb-8 rounded-2xl border border-red-500/30 bg-red-500/10 px-6 py-5 text-primary-text"
            role="alert"
            aria-live="assertive"
            tabindex="-1"
          >
            <p class="font-bold text-secondary-text mb-2">Mesajul nu a putut fi trimis.</p>
            <p id="form-error-text" class="text-primary-text/70">
              Te rugăm să verifici câmpurile și să încerci din nou.
            </p>
          </div>

          <form class="space-y-6" method="POST" name="contact" data-netlify="true" netlify-honeypot="bot-field" action="/.netlify/functions/validate-form" novalidate>
            <input type="hidden" name="form-name" value="contact" />
            <input type="hidden" name="redirect-success" value="/contact?success=true" />
            <input type="hidden" name="redirect-error" value="/contact" />
            <p class="hidden">
              <label>Nu completa dacă ești om: <input name="bot-field" /></label>
            </p>

            <div>
              <label
                for="name"
                class="block text-sm font-bold uppercase tracking-[0.2em] text-primary-text/70 mb-2"
              >
                Nume
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-6 py-4 bg-primary-bg border border-secondary-text/20 rounded-lg focus:outline-none focus:border-accent transition-colors duration-300"
                autocomplete="name"
                aria-required="true"
              />
            </div>

            <div>
              <label
                for="email"
                class="block text-sm font-bold uppercase tracking-[0.2em] text-primary-text/70 mb-2"
              >
                Email
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-6 py-4 bg-primary-bg border border-secondary-text/20 rounded-lg focus:outline-none focus:border-accent transition-colors duration-300"
                autocomplete="email"
                aria-required="true"
              />
            </div>

            <div>
              <label
                for="phone"
                class="block text-sm font-bold uppercase tracking-[0.2em] text-primary-text/70 mb-2"
              >
                Telefon
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                required
                class="w-full px-6 py-4 bg-primary-bg border border-secondary-text/20 rounded-lg focus:outline-none focus:border-accent transition-colors duration-300"
                autocomplete="tel"
                aria-required="true"
              />
            </div>

            <div>
              <label
                for="project"
                class="block text-sm font-bold uppercase tracking-[0.2em] text-primary-text/70 mb-2"
              >
                Tip Proiect
              </label>
              <select
                id="project"
                name="project"
                required
                class="w-full px-6 py-4 bg-primary-bg border border-secondary-text/20 rounded-lg focus:outline-none focus:border-accent transition-colors duration-300"
                autocomplete="off"
                aria-required="true"
              >
                <option value="">Selectează tipul proiectului</option>
                <option value="custom">Mobilier Personalizat</option>
                <option value="restoration">Restaurare</option>
                <option value="consultation">Consultație</option>
                <option value="other">Altele</option>
              </select>
            </div>

            <div>
              <label
                for="message"
                class="block text-sm font-bold uppercase tracking-[0.2em] text-primary-text/70 mb-2"
              >
                Mesaj
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows="6"
                class="w-full px-6 py-4 bg-primary-bg border border-secondary-text/20 rounded-lg focus:outline-none focus:border-accent transition-colors duration-300 resize-none"
                autocomplete="off"
                aria-required="true"
              ></textarea>
            </div>

            <TurnstileWidget />

            <button
              type="submit"
              class="w-full bg-accent text-primary-bg px-12 py-4 rounded-full text-sm uppercase font-bold tracking-[0.2em] hover:bg-secondary-text transition-colors duration-500"
            >
              Trimite Mesajul
            </button>
          </form>
        </div>

        <!-- Contact Info -->
        <div class="reveal-up" style="transition-delay: 100ms">
          <h2 class="text-3xl md:text-4xl font-black text-secondary-text tracking-tighter mb-8">
            Vizitează Atelierul
          </h2>

          <div class="space-y-8 mb-12">
            <div>
              <h3 class="util-label text-accent mb-4">Adresă</h3>
              <address class="not-italic text-lg text-primary-text/70 leading-relaxed">
                Str. Meșteșugului nr. 24<br />
                Bacău, BC 600001<br />
                România
              </address>
            </div>

            <div>
              <h3 class="util-label text-accent mb-4">Contact</h3>
              <div class="text-lg text-primary-text/70 space-y-2">
                <p>
                  <a href="mailto:contact@inuwood.ro" class="hover:text-accent transition-colors">
                    contact@inuwood.ro
                  </a>
                </p>
                <p>
                  <a href="tel:+40234555198" class="hover:text-accent transition-colors">
                    +40 234 555 198
                  </a>
                </p>
              </div>
            </div>

            <div>
              <h3 class="util-label text-accent mb-4">Program</h3>
              <div class="text-lg text-primary-text/70 space-y-1">
                <p>Luni - Vineri: 9:00 - 17:00</p>
                <p>Sâmbătă: 10:00 - 15:00</p>
                <p>Duminică: Închis</p>
              </div>
            </div>
          </div>

          <div class="bg-primary-bg p-8 rounded-[24px]">
            <h3 class="text-xl font-black text-secondary-text mb-4">Vizite la Atelier</h3>
            <p class="text-base text-primary-text/70 leading-relaxed">
              Primim vizitatori în atelierul nostru cu programare. Stabilește o vizită pentru a vedea meșteșugarii noștri la lucru și pentru a discuta despre proiectul tău în persoană.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Structured Data for Contact Page -->
  <LocalBusinessSchema includedIn="ContactPage" />

  <script is:inline>
    const params = new URLSearchParams(window.location.search);
    const successMessage = document.getElementById('form-success');
    const errorMessage = document.getElementById('form-error');
    const errorText = document.getElementById('form-error-text');
    const errors = {
      required: 'Toate câmpurile sunt obligatorii.',
      email: 'Te rugăm să introduci o adresă de email validă.',
      phone: 'Te rugăm să introduci un număr de telefon valid.',
      verification: 'Verificarea anti-spam a eșuat. Te rugăm să încerci din nou.',
      server: 'A apărut o eroare la trimitere. Te rugăm să încerci din nou.',
      'bad-request': 'Cererea trimisă nu este validă. Te rugăm să încerci din nou.',
    };

    if (params.get('success') === 'true' && successMessage) {
      successMessage.classList.remove('hidden');
      successMessage.focus({ preventScroll: true });
      successMessage.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    if (params.has('error') && errorMessage) {
      const errorCode = params.get('error');
      if (errorText && errors[errorCode]) {
        errorText.textContent = errors[errorCode];
      }
      errorMessage.classList.remove('hidden');
      errorMessage.focus({ preventScroll: true });
      errorMessage.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  </script>
</Layout>
