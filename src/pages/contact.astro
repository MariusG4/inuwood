---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us | Wood & Grain" description="Get in touch with our team to discuss your custom furniture project or restoration needs.">
  <!-- Hero Section -->
  <section class="min-h-[40vh] pt-[80px] flex items-center px-6 md:px-12 max-w-[1440px] mx-auto">
    <div class="w-full py-20">
      <div class="reveal-up">
        <span class="util-label text-accent mb-4 block">Get in Touch</span>
        <h1 class="text-6xl md:text-8xl font-black text-secondary-text tracking-tighter mb-8">
          Contact Us
        </h1>
        <p class="text-xl md:text-2xl text-primary-text/70 max-w-3xl font-light leading-relaxed">
          Have a project in mind? We'd love to hear from you. Fill out the form below or reach out
          directly.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="py-32 md:py-48 px-6 md:px-12 bg-secondary-bg">
    <div class="max-w-[1440px] mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
        <!-- Contact Form -->
        <div class="reveal-up">
          <h2 class="text-3xl md:text-4xl font-black text-secondary-text tracking-tighter mb-8">
            Send Us a Message
          </h2>
          <form class="space-y-6">
            <div>
              <label
                for="name"
                class="block text-sm font-bold uppercase tracking-[0.2em] text-primary-text/70 mb-2"
              >
                Name
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-6 py-4 bg-primary-bg border border-secondary-text/20 rounded-lg focus:outline-none focus:border-accent transition-colors duration-300"
              />
            </div>

            <div>
              <label
                for="email"
                class="block text-sm font-bold uppercase tracking-[0.2em] text-primary-text/70 mb-2"
              >
                Email
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-6 py-4 bg-primary-bg border border-secondary-text/20 rounded-lg focus:outline-none focus:border-accent transition-colors duration-300"
              />
            </div>

            <div>
              <label
                for="phone"
                class="block text-sm font-bold uppercase tracking-[0.2em] text-primary-text/70 mb-2"
              >
                Phone (Optional)
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                class="w-full px-6 py-4 bg-primary-bg border border-secondary-text/20 rounded-lg focus:outline-none focus:border-accent transition-colors duration-300"
              />
            </div>

            <div>
              <label
                for="project"
                class="block text-sm font-bold uppercase tracking-[0.2em] text-primary-text/70 mb-2"
              >
                Project Type
              </label>
              <select
                id="project"
                name="project"
                required
                class="w-full px-6 py-4 bg-primary-bg border border-secondary-text/20 rounded-lg focus:outline-none focus:border-accent transition-colors duration-300"
              >
                <option value="">Select a project type</option>
                <option value="custom">Custom Furniture</option>
                <option value="restoration">Restoration</option>
                <option value="consultation">Consultation</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div>
              <label
                for="message"
                class="block text-sm font-bold uppercase tracking-[0.2em] text-primary-text/70 mb-2"
              >
                Message
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows="6"
                class="w-full px-6 py-4 bg-primary-bg border border-secondary-text/20 rounded-lg focus:outline-none focus:border-accent transition-colors duration-300 resize-none"
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full bg-accent text-primary-bg px-12 py-4 rounded-full text-sm uppercase font-bold tracking-[0.2em] hover:bg-secondary-text transition-colors duration-500"
            >
              Send Message
            </button>
          </form>
        </div>

        <!-- Contact Info -->
        <div class="reveal-up" style="transition-delay: 100ms">
          <h2 class="text-3xl md:text-4xl font-black text-secondary-text tracking-tighter mb-8">
            Visit Our Workshop
          </h2>
          
          <div class="space-y-8 mb-12">
            <div>
              <h3 class="util-label text-accent mb-4">Address</h3>
              <address class="not-italic text-lg text-primary-text/70 leading-relaxed">
                124 Timberline Way<br />
                Portland, OR 97204<br />
                United States
              </address>
            </div>

            <div>
              <h3 class="util-label text-accent mb-4">Contact</h3>
              <div class="text-lg text-primary-text/70 space-y-2">
                <p>
                  <a
                    href="mailto:hello@woodandgrain.com"
                    class="hover:text-accent transition-colors"
                  >
                    hello@woodandgrain.com
                  </a>
                </p>
                <p>
                  <a href="tel:+15035550198" class="hover:text-accent transition-colors">
                    +1 (503) 555-0198
                  </a>
                </p>
              </div>
            </div>

            <div>
              <h3 class="util-label text-accent mb-4">Hours</h3>
              <div class="text-lg text-primary-text/70 space-y-1">
                <p>Monday - Friday: 9:00 AM - 5:00 PM</p>
                <p>Saturday: 10:00 AM - 3:00 PM</p>
                <p>Sunday: Closed</p>
              </div>
            </div>
          </div>

          <div class="bg-primary-bg p-8 rounded-[24px]">
            <h3 class="text-xl font-black text-secondary-text mb-4">Workshop Visits</h3>
            <p class="text-base text-primary-text/70 leading-relaxed">
              We welcome visitors to our workshop by appointment. Schedule a visit to see our
              craftspeople at work and discuss your project in person.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
