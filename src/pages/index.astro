---
import Layout from '../layouts/Layout.astro';
import LocalBusinessSchema from '../components/SEO/LocalBusinessSchema.astro';
import SectionHeader from '../components/UI/SectionHeader.astro';
import ProductCard from '../components/UI/ProductCard.astro';
import NewsletterSignup from '../components/UI/NewsletterSignup.astro';
import CloudinaryImage from '../components/CloudinaryImage.astro';

const pageTitle = "InuWood - Mobilier din Lemn Masiv Realizat Manual";
const pageDescription = "Atelier de tâmplărie artizanală în Bacău. Creăm mobilier din lemn masiv cu tehnici tradiționale, design personalizat și calitate superioară. Comenzi și restaurări mobilier.";
const pageKeywords = "mobilier lemn masiv Bacău, tâmplărie artizanală, mobilier handmade, design mobilier personalizat, restaurare mobilier lemn, mobila din stejar, mobila din nuc, atelier lemn Bacău";

const featuredProducts = [
  {
    title: 'Oglinda Artizanului',
    category: 'Oglinda',
    wood: 'Nuc',
    year: '2024',
    image: 'homepage/oglinda-homepage',
    alt: 'Oglinda artizanal din lemn de nuc cu finisaj manual',
    slug: 'oglinda-artizanala'
  },
  {
    title: 'Tocator Live Edge',
    category: 'Platou/Tocator',
    wood: 'Stejar',
    year: '2024',
    image: 'homepage/tocatoare-homepage',
    alt: 'Platou de dining din stejar cu margine naturală live edge',
    slug: 'set-platou-tocator-lemn-live-edge'
  }
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  keywords={pageKeywords}
  ogType="website"
>
  <!-- Hero Section -->
  <section
    class="min-h-screen pt-[80px] flex items-center px-6 md:px-12 max-w-[1440px] mx-auto relative"
    aria-labelledby="hero-heading"
  >
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 w-full items-center py-20 lg:py-0">
      <!-- Left: Typography -->
      <div class="lg:col-span-7 z-10">
        <h1
          id="hero-heading"
          class="text-[15vw] lg:text-[11vw] font-black leading-[0.75] tracking-tighter text-secondary-text reveal-up uppercase"
        >
          Lemn <br />
          <span class="text-accent font-medium lowercase italic tracking-normal pr-4"
            >meșteșugit</span
          >
          <br />
          Manual
        </h1>
        <p
          class="text-xl md:text-2xl text-primary-text/70 mt-10 max-w-md reveal-up font-light leading-relaxed"
          style="transition-delay: 100ms"
        >
          Transformăm materia primă în piese de mobilier care vor dăinui generații. Lemn masiv, îmbinări tradiționale, calitate fără compromis.
        </p>
        <div class="reveal-up mt-16" style="transition-delay: 200ms">
          <a
            href="/products"
            class="inline-flex items-center gap-4 pb-2 border-b-2 border-accent text-accent font-black uppercase text-[10px] tracking-[0.4em] hover:text-secondary-text hover:border-secondary-text transition-colors duration-500"
            aria-label="Explorează portofoliul nostru de produse"
          >
            Explorează Lucrările
            <iconify-icon icon="lucide:arrow-right" class="text-lg" aria-hidden="true"></iconify-icon>
          </a>
        </div>
      </div>

      <!-- Right: Visual Element -->
      <div class="lg:col-span-5 relative reveal-up" style="transition-delay: 300ms">
        <div class="relative aspect-[3/4] overflow-hidden rounded-[24px]">
          <CloudinaryImage
            src="https://images.unsplash.com/photo-1615529182904-14819c35db37?auto=format&fit=crop&q=80&w=800"
            alt="Detaliu mobilier din lemn meșteșugit manual în atelierul InuWood"
            width={800}
            height={1067}
            class="w-full h-full object-cover"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="py-32 md:py-48 px-6 md:px-12 bg-secondary-bg" aria-labelledby="services-heading">
    <div class="max-w-[1440px] mx-auto">
      <SectionHeader
        label="Serviciile Noastre"
        heading="Meșteșug & Experiență"
        headingId="services-heading"
      />

      <div class="grid grid-cols-1 lg:grid-cols-3 border-t border-l border-secondary-text/20">
        <!-- Service 1 -->
        <article
          class="group border-r border-b border-secondary-text/20 p-10 md:p-14 bg-primary-bg hover:bg-accent transition-colors duration-1000 ease-custom reveal-up cursor-pointer"
        >
          <div class="mb-16" aria-hidden="true">
            <iconify-icon
              icon="ph:tree-structure-bold"
              class="text-5xl text-secondary-text group-hover:text-primary-bg transition-colors duration-1000 ease-custom"
            ></iconify-icon>
          </div>
          <h3
            class="font-black uppercase text-2xl md:text-3xl tracking-tight text-secondary-text group-hover:text-primary-bg mb-6 transition-colors duration-1000 ease-custom"
          >
            Îmbinări
          </h3>
          <p
            class="text-base leading-relaxed text-primary-text/70 group-hover:text-primary-bg/80 transition-colors duration-1000 ease-custom"
          >
            Îmbinări tradiționale realizate manual - cep și gaură, coadă de rândunică - care asigură rezistență pe generații întregi.
          </p>
        </article>

        <!-- Service 2 -->
        <article
          class="group border-r border-b border-secondary-text/20 p-10 md:p-14 bg-primary-bg hover:bg-accent transition-colors duration-1000 ease-custom reveal-up cursor-pointer"
          style="transition-delay: 100ms"
        >
          <div class="mb-16" aria-hidden="true">
            <iconify-icon
              icon="ph:ruler-bold"
              class="text-5xl text-secondary-text group-hover:text-primary-bg transition-colors duration-1000 ease-custom"
            ></iconify-icon>
          </div>
          <h3
            class="font-black uppercase text-2xl md:text-3xl tracking-tight text-secondary-text group-hover:text-primary-bg mb-6 transition-colors duration-1000 ease-custom"
          >
            Design Personalizat
          </h3>
          <p
            class="text-base leading-relaxed text-primary-text/70 group-hover:text-primary-bg/80 transition-colors duration-1000 ease-custom"
          >
            Piese realizate după specificațiile tale exacte, îmbinând funcționalitatea cu estetica intemporală.
          </p>
        </article>

        <!-- Service 3 -->
        <article
          class="group border-r border-b border-secondary-text/20 p-10 md:p-14 bg-primary-bg hover:bg-accent transition-colors duration-1000 ease-custom reveal-up cursor-pointer"
          style="transition-delay: 200ms"
        >
          <div class="mb-16" aria-hidden="true">
            <iconify-icon
              icon="ph:hand-heart-bold"
              class="text-5xl text-secondary-text group-hover:text-primary-bg transition-colors duration-1000 ease-custom"
            ></iconify-icon>
          </div>
          <h3
            class="font-black uppercase text-2xl md:text-3xl tracking-tight text-secondary-text group-hover:text-primary-bg mb-6 transition-colors duration-1000 ease-custom"
          >
            Restaurare
          </h3>
          <p
            class="text-base leading-relaxed text-primary-text/70 group-hover:text-primary-bg/80 transition-colors duration-1000 ease-custom"
          >
            Redăm viață mobilierului antic printr-o restaurare atentă care respectă meșteșugul original.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- Portfolio Preview Section -->
  <section class="py-32 md:py-48 px-6 md:px-12 bg-primary-bg" aria-labelledby="portfolio-heading">
    <div class="max-w-[1440px] mx-auto">
      <header class="mb-20 reveal-up flex justify-between items-end">
        <div>
          <span class="util-label text-accent mb-4 block">Proiecte Recente</span>
          <h2 id="portfolio-heading" class="text-5xl md:text-7xl font-black text-secondary-text tracking-tighter">
            Lucrări Selectate
          </h2>
        </div>
        <a
          href="/products"
          class="hidden md:inline-flex items-center gap-4 pb-2 border-b-2 border-accent text-accent font-black uppercase text-[10px] tracking-[0.4em] hover:text-secondary-text hover:border-secondary-text transition-colors duration-500"
          aria-label="Vezi toate produsele"
        >
          Vezi Toate
          <iconify-icon icon="lucide:arrow-right" class="text-lg" aria-hidden="true"></iconify-icon>
        </a>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 lg:gap-x-16 gap-y-24">
        <ProductCard {...featuredProducts[0]} slug={featuredProducts[0].slug} />
        <div class="md:pt-[120px]">
          <ProductCard {...featuredProducts[1]} slug={featuredProducts[1].slug} delay={100} />
        </div>
      </div>
    </div>
  </section>

  <NewsletterSignup variant="home" source="homepage" />

  <!-- Structured Data for WebPage with LocalBusiness -->
  <LocalBusinessSchema includedIn="WebPage" />
</Layout>
