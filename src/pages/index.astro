---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Wood & Grain | Bespoke Craftsmanship">
  <!-- Hero Section -->
  <section
    class="min-h-screen pt-[80px] flex items-center px-6 md:px-12 max-w-[1440px] mx-auto relative"
  >
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 w-full items-center py-20 lg:py-0">
      <!-- Left: Typography -->
      <div class="lg:col-span-7 z-10">
        <h1
          class="text-[15vw] lg:text-[11vw] font-black leading-[0.75] tracking-tighter text-secondary-text reveal-up uppercase"
        >
          Timber <br />
          <span class="text-accent font-medium lowercase italic tracking-normal pr-4"
            >handcrafted</span
          >
          <br />
          Form
        </h1>
        <p
          class="text-xl md:text-2xl text-primary-text/70 mt-10 max-w-md reveal-up font-light leading-relaxed"
          style="transition-delay: 100ms"
        >
          We shape raw nature into enduring legacy pieces. Solid wood, traditional joinery,
          uncompromised quality.
        </p>
        <div class="reveal-up mt-16" style="transition-delay: 200ms">
          <a
            href="/products"
            class="inline-flex items-center gap-4 pb-2 border-b-2 border-accent text-accent font-black uppercase text-[10px] tracking-[0.4em] hover:text-secondary-text hover:border-secondary-text transition-colors duration-500"
          >
            Explore Works
            <iconify-icon icon="lucide:arrow-right" class="text-lg"></iconify-icon>
          </a>
        </div>
      </div>

      <!-- Right: Visual Element -->
      <div class="lg:col-span-5 relative reveal-up" style="transition-delay: 300ms">
        <div class="relative aspect-[3/4] overflow-hidden rounded-[24px]">
          <img
            src="https://images.unsplash.com/photo-1615529182904-14819c35db37?auto=format&fit=crop&q=80&w=800"
            alt="Handcrafted woodwork detail"
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="py-32 md:py-48 px-6 md:px-12 bg-secondary-bg">
    <div class="max-w-[1440px] mx-auto">
      <header class="mb-20 reveal-up">
        <span class="util-label text-accent mb-4 block">Our Services</span>
        <h2 class="text-5xl md:text-7xl font-black text-secondary-text tracking-tighter">
          Craft & Expertise
        </h2>
      </header>

      <div class="grid grid-cols-1 lg:grid-cols-3 border-t border-l border-secondary-text/20">
        <!-- Service 1 -->
        <article
          class="group border-r border-b border-secondary-text/20 p-10 md:p-14 bg-primary-bg hover:bg-accent transition-colors duration-1000 ease-custom reveal-up cursor-pointer"
        >
          <div class="mb-16">
            <iconify-icon
              icon="ph:tree-structure-bold"
              class="text-5xl text-secondary-text group-hover:text-primary-bg transition-colors duration-1000 ease-custom"
            ></iconify-icon>
          </div>
          <h3
            class="font-black uppercase text-2xl md:text-3xl tracking-tight text-secondary-text group-hover:text-primary-bg mb-6 transition-colors duration-1000 ease-custom"
          >
            Joinery
          </h3>
          <p
            class="text-base leading-relaxed text-primary-text/70 group-hover:text-primary-bg/80 transition-colors duration-1000 ease-custom"
          >
            Traditional mortise-and-tenon, dovetail, and hand-cut joinery ensuring strength that
            lasts generations.
          </p>
        </article>

        <!-- Service 2 -->
        <article
          class="group border-r border-b border-secondary-text/20 p-10 md:p-14 bg-primary-bg hover:bg-accent transition-colors duration-1000 ease-custom reveal-up cursor-pointer"
          style="transition-delay: 100ms"
        >
          <div class="mb-16">
            <iconify-icon
              icon="ph:ruler-bold"
              class="text-5xl text-secondary-text group-hover:text-primary-bg transition-colors duration-1000 ease-custom"
            ></iconify-icon>
          </div>
          <h3
            class="font-black uppercase text-2xl md:text-3xl tracking-tight text-secondary-text group-hover:text-primary-bg mb-6 transition-colors duration-1000 ease-custom"
          >
            Custom Design
          </h3>
          <p
            class="text-base leading-relaxed text-primary-text/70 group-hover:text-primary-bg/80 transition-colors duration-1000 ease-custom"
          >
            Tailored pieces designed to your exact specifications, blending function with timeless
            aesthetics.
          </p>
        </article>

        <!-- Service 3 -->
        <article
          class="group border-r border-b border-secondary-text/20 p-10 md:p-14 bg-primary-bg hover:bg-accent transition-colors duration-1000 ease-custom reveal-up cursor-pointer"
          style="transition-delay: 200ms"
        >
          <div class="mb-16">
            <iconify-icon
              icon="ph:hand-heart-bold"
              class="text-5xl text-secondary-text group-hover:text-primary-bg transition-colors duration-1000 ease-custom"
            ></iconify-icon>
          </div>
          <h3
            class="font-black uppercase text-2xl md:text-3xl tracking-tight text-secondary-text group-hover:text-primary-bg mb-6 transition-colors duration-1000 ease-custom"
          >
            Restoration
          </h3>
          <p
            class="text-base leading-relaxed text-primary-text/70 group-hover:text-primary-bg/80 transition-colors duration-1000 ease-custom"
          >
            Breathe new life into heirloom furniture with careful restoration respecting original
            craftsmanship.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- Portfolio Preview Section -->
  <section class="py-32 md:py-48 px-6 md:px-12 bg-primary-bg">
    <div class="max-w-[1440px] mx-auto">
      <header class="mb-20 reveal-up flex justify-between items-end">
        <div>
          <span class="util-label text-accent mb-4 block">Recent Projects</span>
          <h2 class="text-5xl md:text-7xl font-black text-secondary-text tracking-tighter">
            Featured Works
          </h2>
        </div>
        <a
          href="/products"
          class="hidden md:inline-flex items-center gap-4 pb-2 border-b-2 border-accent text-accent font-black uppercase text-[10px] tracking-[0.4em] hover:text-secondary-text hover:border-secondary-text transition-colors duration-500"
        >
          View All
          <iconify-icon icon="lucide:arrow-right" class="text-lg"></iconify-icon>
        </a>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 lg:gap-x-16 gap-y-24">
        <!-- Portfolio Item 1 -->
        <article class="group reveal-up">
          <a
            href="/products"
            class="block relative rounded-[16px] overflow-hidden aspect-[3/4] mb-8"
          >
            <img
              src="https://images.unsplash.com/photo-1505693314120-0d443867891c?auto=format&fit=crop&q=80&w=1200"
              alt="The Artisan Chair"
              class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-[1.08] transition-all duration-1000 ease-custom"
            />
            <div
              class="absolute inset-0 bg-primary-text/20 opacity-0 group-hover:opacity-100 transition-opacity duration-1000 ease-custom flex items-center justify-center z-10"
            >
              <span
                class="w-[96px] h-[96px] rounded-full bg-primary-text flex items-center justify-center text-primary-bg util-label text-[9px] transform scale-50 group-hover:scale-100 transition-transform duration-1000 ease-custom"
              >
                View
              </span>
            </div>
          </a>
          <div>
            <span class="util-label text-accent mb-4 block">Seating</span>
            <h3 class="text-3xl md:text-4xl font-black text-secondary-text tracking-tighter mb-3">
              The Artisan Chair
            </h3>
            <div class="text-sm text-primary-text/60 font-medium">Walnut &bull; 2024</div>
          </div>
        </article>

        <!-- Portfolio Item 2 -->
        <article class="group reveal-up md:pt-[120px]" style="transition-delay: 100ms">
          <a
            href="/products"
            class="block relative rounded-[16px] overflow-hidden aspect-[3/4] mb-8"
          >
            <img
              src="https://images.unsplash.com/photo-1538688525198-9b88f6f53126?auto=format&fit=crop&q=80&w=1200"
              alt="Dining Table"
              class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-[1.08] transition-all duration-1000 ease-custom"
            />
            <div
              class="absolute inset-0 bg-primary-text/20 opacity-0 group-hover:opacity-100 transition-opacity duration-1000 ease-custom flex items-center justify-center z-10"
            >
              <span
                class="w-[96px] h-[96px] rounded-full bg-primary-text flex items-center justify-center text-primary-bg util-label text-[9px] transform scale-50 group-hover:scale-100 transition-transform duration-1000 ease-custom"
              >
                View
              </span>
            </div>
          </a>
          <div>
            <span class="util-label text-accent mb-4 block">Tables</span>
            <h3 class="text-3xl md:text-4xl font-black text-secondary-text tracking-tighter mb-3">
              Live Edge Dining
            </h3>
            <div class="text-sm text-primary-text/60 font-medium">Oak &bull; 2024</div>
          </div>
        </article>
      </div>
    </div>
  </section>
</Layout>
