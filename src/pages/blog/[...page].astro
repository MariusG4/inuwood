---
import type { GetStaticPaths, Page } from 'astro';
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/UI/Hero.astro';
import BlogCard from '../../components/UI/BlogCard.astro';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const allPosts = await getCollection('blog', ({ data }) => {
    return data.draft !== true;
  });

  // Sortează după dată (cele mai noi primul)
  const sortedPosts = allPosts.sort((a, b) => {
    const dateA = new Date(a.data.date);
    const dateB = new Date(b.data.date);
    return dateB.getTime() - dateA.getTime();
  });

  return paginate(sortedPosts, { pageSize: 6 });
};

const { page } = Astro.props as { page: Page };

const pageTitle = page.currentPage === 1
  ? "Blog - Tehnici & Povești | InuWood"
  : `Blog - Pagina ${page.currentPage} | InuWood`;

const pageDescription = "Descoperă articole despre tehnici de tâmplărie, design de mobilier, practici sustenabile și povești din atelierul InuWood Bacău.";
const pageKeywords = "blog tâmplărie, tehnici lemn masiv, design mobilier articole, îmbinări lemn tutorial, restaurare mobilier ghid, sfaturi amenajare lemn";
---

<Layout
  title={pageTitle}
  description={pageDescription}
  keywords={pageKeywords}
>
  <!-- Hero Section -->
  <Hero
    label="Povești & Insight-uri"
    heading="Blogul Nostru"
    description="Explorează articole despre tehnici de tâmplărie, filosofia de design și meșteșugul din spatele fiecărei piese pe care o creăm."
    ariaLabelledBy="blog-heading"
  />

  <!-- Blog Grid -->
  <section class="py-32 md:py-48 px-6 md:px-12 bg-primary-bg">
    <div class="max-w-[1440px] mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 lg:gap-x-12 gap-y-16">
        {page.data.map((post, index) => (
          <BlogCard
            title={post.data.title}
            excerpt={post.data.excerpt}
            date={post.data.date}
            category={post.data.category}
            image={post.data.image}
            readTime={post.data.readTime}
            slug={post.slug}
            delay={index * 50}
          />
        ))}
      </div>

      <!-- Pagination -->
      {(page.lastPage > 1) && (
        <nav class="mt-20 flex justify-center items-center gap-4" aria-label="Navigare pagini blog">
          {page.url.prev && (
            <a
              href={page.url.prev}
              class="inline-flex items-center gap-2 px-6 py-3 bg-secondary-bg text-secondary-text rounded-full font-bold text-sm uppercase tracking-[0.2em] hover:bg-accent hover:text-primary-bg transition-colors duration-300"
              aria-label="Pagina anterioară"
            >
              <iconify-icon icon="lucide:arrow-left" class="text-base"></iconify-icon>
              Anterior
            </a>
          )}

          <div class="flex items-center gap-2">
            {Array.from({ length: page.lastPage }, (_, i) => i + 1).map((num) => (
              <a
                href={num === 1 ? '/blog' : `/blog/${num}`}
                class={`w-10 h-10 flex items-center justify-center rounded-full font-bold text-sm transition-colors duration-300 ${
                  num === page.currentPage
                    ? 'bg-accent text-primary-bg'
                    : 'bg-secondary-bg text-secondary-text hover:bg-accent hover:text-primary-bg'
                }`}
                aria-label={`Pagina ${num}`}
                aria-current={num === page.currentPage ? 'page' : undefined}
              >
                {num}
              </a>
            ))}
          </div>

          {page.url.next && (
            <a
              href={page.url.next}
              class="inline-flex items-center gap-2 px-6 py-3 bg-secondary-bg text-secondary-text rounded-full font-bold text-sm uppercase tracking-[0.2em] hover:bg-accent hover:text-primary-bg transition-colors duration-300"
              aria-label="Pagina următoare"
            >
              Următor
              <iconify-icon icon="lucide:arrow-right" class="text-base"></iconify-icon>
            </a>
          )}
        </nav>
      )}
    </div>
  </section>

  <!-- Newsletter Section -->
  <section class="py-32 md:py-48 px-6 md:px-12 bg-secondary-bg">
    <div class="max-w-[1440px] mx-auto">
      <div class="max-w-3xl mx-auto text-center reveal-up">
        <h2 class="text-4xl md:text-6xl font-black text-secondary-text tracking-tighter mb-8">
          Rămâi Inspirat
        </h2>
        <p class="text-xl text-primary-text/70 mb-12">
          Abonează-te la newsletter-ul nostru pentru sfaturi de tâmplărie, actualizări despre proiecte și insight-uri exclusive din atelierul nostru.
        </p>
        <form class="flex flex-col sm:flex-row gap-4 max-w-xl mx-auto" method="POST" name="newsletter" data-netlify="true">
          <input type="hidden" name="form-name" value="newsletter" />
          <input
            type="email"
            name="email"
            placeholder="Adresa ta de email"
            required
            autocomplete="email"
            class="flex-1 px-6 py-4 bg-primary-bg border border-secondary-text/20 rounded-full focus:outline-none focus:border-accent transition-colors duration-300"
            aria-label="Adresa de email pentru newsletter"
          />
          <button
            type="submit"
            class="bg-accent text-primary-bg px-8 py-4 rounded-full text-sm uppercase font-bold tracking-[0.2em] hover:bg-secondary-text transition-colors duration-500 whitespace-nowrap"
          >
            Abonează-te
          </button>
        </form>
      </div>
    </div>
  </section>

  <!-- Structured Data for Blog -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Blog",
    "name": "Blog InuWood",
    "description": "Articole despre tehnici de tâmplărie, design de mobilier și povești din atelierul nostru",
    "url": "https://inuwood.ro/blog",
    "inLanguage": "ro-RO",
    "publisher": {
      "@type": "Organization",
      "name": "InuWood",
      "logo": {
        "@type": "ImageObject",
        "url": "https://inuwood.ro/favicon.svg"
      }
    }
  })} />
</Layout>
