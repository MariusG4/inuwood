---
import Layout from '../layouts/Layout.astro';

const products = [
  {
    title: 'The Artisan Chair',
    category: 'Seating',
    wood: 'Walnut',
    year: '2024',
    image: 'https://images.unsplash.com/photo-1505693314120-0d443867891c?auto=format&fit=crop&q=80&w=1200'
  },
  {
    title: 'Live Edge Dining',
    category: 'Tables',
    wood: 'Oak',
    year: '2024',
    image: 'https://images.unsplash.com/photo-1538688525198-9b88f6f53126?auto=format&fit=crop&q=80&w=1200'
  },
  {
    title: 'Lounge Frame',
    category: 'Framework',
    wood: 'White Oak',
    year: '2023',
    image: 'https://images.unsplash.com/photo-1586023492125-27b2c045efd7?auto=format&fit=crop&q=80&w=1200'
  },
  {
    title: 'Credenza Detail',
    category: 'Storage',
    wood: 'Cherry',
    year: '2023',
    image: 'https://images.unsplash.com/photo-1595428774223-ef52624120d2?auto=format&fit=crop&q=80&w=1200'
  },
  {
    title: 'Executive Desk',
    category: 'Workspace',
    wood: 'Maple',
    year: '2024',
    image: 'https://images.unsplash.com/photo-1518455027359-f3f8164ba6bd?auto=format&fit=crop&q=80&w=1200'
  },
  {
    title: 'Floating Shelf',
    category: 'Storage',
    wood: 'Ash',
    year: '2023',
    image: 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?auto=format&fit=crop&q=80&w=1200'
  }
];
---

<Layout title="Products | Wood & Grain" description="Explore our collection of handcrafted furniture pieces, each one built with traditional joinery and sustainably sourced hardwoods.">
  <!-- Hero Section -->
  <section class="min-h-[60vh] pt-[80px] flex items-center px-6 md:px-12 max-w-[1440px] mx-auto">
    <div class="w-full py-20">
      <div class="reveal-up">
        <span class="util-label text-accent mb-4 block">Our Collection</span>
        <h1 class="text-6xl md:text-8xl font-black text-secondary-text tracking-tighter mb-8">
          Handcrafted Products
        </h1>
        <p class="text-xl md:text-2xl text-primary-text/70 max-w-3xl font-light leading-relaxed">
          Each piece is meticulously crafted using traditional joinery techniques and sustainably
          sourced hardwoods. Browse our portfolio of completed works.
        </p>
      </div>
    </div>
  </section>

  <!-- Portfolio Grid -->
  <section class="py-32 md:py-48 px-6 md:px-12 bg-primary-bg">
    <div class="max-w-[1440px] mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 lg:gap-x-16 gap-y-24">
        <!-- Column 1 (Odds) -->
        <div class="flex flex-col gap-y-24">
          {products.filter((_, i) => i % 2 === 0).map((product) => (
            <article class="group reveal-up">
              <div class="block relative rounded-[16px] overflow-hidden aspect-[3/4] mb-8">
                <img
                  src={product.image}
                  alt={product.title}
                  class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-[1.08] transition-all duration-1000 ease-custom"
                />
                <div class="absolute inset-0 bg-primary-text/20 opacity-0 group-hover:opacity-100 transition-opacity duration-1000 ease-custom flex items-center justify-center z-10">
                  <span class="w-[96px] h-[96px] rounded-full bg-primary-text flex items-center justify-center text-primary-bg util-label text-[9px] transform scale-50 group-hover:scale-100 transition-transform duration-1000 ease-custom">
                    View
                  </span>
                </div>
              </div>
              <div>
                <span class="util-label text-accent mb-4 block">{product.category}</span>
                <h3 class="text-3xl md:text-4xl font-black text-secondary-text tracking-tighter mb-3">
                  {product.title}
                </h3>
                <div class="text-sm text-primary-text/60 font-medium">
                  {product.wood} &bull; {product.year}
                </div>
              </div>
            </article>
          ))}
        </div>

        <!-- Column 2 (Evens - Staggered) -->
        <div class="flex flex-col gap-y-24 md:pt-[120px]">
          {products.filter((_, i) => i % 2 === 1).map((product, index) => (
            <article class="group reveal-up" style={`transition-delay: ${(index + 1) * 100}ms`}>
              <div class="block relative rounded-[16px] overflow-hidden aspect-[3/4] mb-8">
                <img
                  src={product.image}
                  alt={product.title}
                  class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-[1.08] transition-all duration-1000 ease-custom"
                />
                <div class="absolute inset-0 bg-primary-text/20 opacity-0 group-hover:opacity-100 transition-opacity duration-1000 ease-custom flex items-center justify-center z-10">
                  <span class="w-[96px] h-[96px] rounded-full bg-primary-text flex items-center justify-center text-primary-bg util-label text-[9px] transform scale-50 group-hover:scale-100 transition-transform duration-1000 ease-custom">
                    View
                  </span>
                </div>
              </div>
              <div>
                <span class="util-label text-accent mb-4 block">{product.category}</span>
                <h3 class="text-3xl md:text-4xl font-black text-secondary-text tracking-tighter mb-3">
                  {product.title}
                </h3>
                <div class="text-sm text-primary-text/60 font-medium">
                  {product.wood} &bull; {product.year}
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-32 md:py-48 px-6 md:px-12 bg-secondary-bg">
    <div class="max-w-[1440px] mx-auto text-center reveal-up">
      <h2 class="text-4xl md:text-6xl font-black text-secondary-text tracking-tighter mb-8">
        Commission a Custom Piece
      </h2>
      <p class="text-xl text-primary-text/70 mb-12 max-w-2xl mx-auto">
        Have a vision for a unique furniture piece? We work closely with clients to bring custom
        designs to life.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center gap-4 bg-accent text-primary-bg px-12 py-4 rounded-full text-sm uppercase font-bold tracking-[0.2em] hover:bg-secondary-text transition-colors duration-500"
      >
        Start Your Project
        <iconify-icon icon="lucide:arrow-right" class="text-lg"></iconify-icon>
      </a>
    </div>
  </section>
</Layout>
